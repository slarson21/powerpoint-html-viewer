<body>

<header>
  <h1>U.S. Residential Water Main<br><em>Pipe Material Estimates</em></h1>
  <p class="subtitle">Main cold water supply line · Flo device install base · Directional estimates only</p>
</header>

<div class="container" id="app"></div>
<footer id="footer"></footer>

<script>
const TOTAL = 78_000_000;

const TABS = [
  { id: 'overall',   label: 'Overall',              flo: 561_148, showHomes: true  },
  { id: 'fl_combo',  label: '900-001 + 900-002',    flo: 287_039, showHomes: false },
  { id: 'fl_125',    label: '900-002',              flo:  73_188, showHomes: false },
  { id: 'fl_1',      label: '900-006',              flo: 274_109, showHomes: false },
  { id: 'fl_075',    label: '900-001',              flo: 213_851, showHomes: false },
  { id: 'fl_split',  label: 'By Model',             flo: 561_148, showHomes: false, isSplit: true },
  { id: 'fl_split2', label: 'By Model (¾" + 1¼")',  flo: 287_039, showHomes: false, isSplit: true, splitModels: [
      { label: '900-001', flo: 213_851 },
      { label: '900-002', flo:  73_188 },
  ]},
];

const OVERALL_FLO = 561_148;
const SPLIT_MODELS = [
  { label: '900-001', flo: 213_851 },
  { label: '900-006', flo: 274_109 },
  { label: '900-002', flo:  73_188 },
];

let currentTab = 0;

const DEFAULTS = [
  {
    id: 'copper', name: 'Copper', color: '#b5541a', pct: 52,
    fittings: [
      { name: 'Solder / sweat male adapter',      share: 0.70 },
      { name: 'Compression male adapter',          share: 0.29 },
      { name: 'Push-fit male adapter (SharkBite)', share: 0.01 },
    ]
  },
  {
    id: 'galv', name: 'Galvanized Steel', color: '#5a6e4a', pct: 20,
    fittings: [
      { name: 'Threaded NPT (rethread direct)',        share: 0.50 },
      { name: 'Dielectric union to threaded nipple',   share: 0.50 },
    ]
  },
  {
    id: 'pex', name: 'PEX', color: '#2a5a8a', pct: 14,
    fittings: [
      { name: 'Crimp/clamp insert male adapter (PEX-B)', share: 0.29 },
      { name: 'Expansion insert male adapter (PEX-A)',   share: 0.70 },
      { name: 'Push-fit male adapter (SharkBite)',       share: 0.01 },
    ]
  },
  {
    id: 'cpvc', name: 'CPVC', color: '#8a4a7a', pct: 4,
    fittings: [
      { name: 'Solvent cement male adapter',        share: 0.99 },
      { name: 'Push-fit male adapter (SharkBite)',  share: 0.01 },
    ]
  },
  {
    id: 'other', name: 'Other', color: '#8a7a5a', pct: 3,
    fittings: [
      { name: 'Compression male adapter',                  share: 0.50 },
      { name: 'Fernco rubber coupling to threaded nipple', share: 0.50 },
    ]
  },
];

const STORAGE_KEY = 'pipe_viz_defaults_v1';

function loadPersistedDefaults() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return null;
    const parsed = JSON.parse(raw);
    if (!Array.isArray(parsed) || parsed.length !== DEFAULTS.length) return null;
    return parsed;
  } catch(e) { return null; }
}

function applyPersistedDefaults(persisted) {
  return DEFAULTS.map((d, i) => {
    const p = persisted[i];
    if (!p || p.id !== d.id) return { ...d, fittings: d.fittings.map(f => ({...f})) };
    return {
      ...d,
      pct: p.pct,
      fittings: d.fittings.map((f, fi) => ({
        ...f,
        share: p.fittings[fi]?.share ?? f.share
      }))
    };
  });
}

const _persisted = loadPersistedDefaults();
let savedDefaults = _persisted
  ? applyPersistedDefaults(_persisted)
  : DEFAULTS.map(d => ({ ...d, fittings: d.fittings.map(f => ({...f})) }));

let state = savedDefaults.map(d => ({ ...d, fittings: d.fittings.map(f => ({...f})) }));

const fmt = n => n >= 1e6 ? (n/1e6).toFixed(1)+'M' : n >= 1e3 ? (n/1e3).toFixed(0)+'K' : n.toFixed(0);
const fmtFlo = n => n >= 1e3 ? (n/1e3).toFixed(1)+'K' : Math.round(n).toLocaleString();
const toHomes = pct => Math.round(pct / 100 * TOTAL);
const toFlo = pct => Math.round(pct / 100 * TABS[currentTab].flo);
const totalPct = () => state.reduce((s, m) => s + m.pct, 0);

// ── Treemap layout (binary split by value) ───────────────────
// Recursively bisects the rectangle, splitting along the longer axis.
// Returns array of {x, y, w, h, ...item} in 0–1 normalised coords.
function treemapLayout(items) {
  const sorted = [...items].sort((a, b) => b.value - a.value);
  const results = [];

  function place(nodes, x, y, w, h) {
    if (!nodes.length) return;
    if (nodes.length === 1) {
      results.push({ ...nodes[0], x, y, w, h });
      return;
    }

    const total = nodes.reduce((s, n) => s + n.value, 0);

    // Find best binary split (minimise difference between two halves)
    let bestDiff = Infinity, splitAt = 1;
    let running = 0;
    for (let i = 0; i < nodes.length - 1; i++) {
      running += nodes[i].value;
      const diff = Math.abs(running - (total - running));
      if (diff < bestDiff) { bestDiff = diff; splitAt = i + 1; }
    }

    const groupA = nodes.slice(0, splitAt);
    const groupB = nodes.slice(splitAt);
    const aFrac  = groupA.reduce((s, n) => s + n.value, 0) / total;

    if (w >= h) {
      // split vertically (two columns)
      place(groupA, x,           y, w * aFrac,       h);
      place(groupB, x + w*aFrac, y, w * (1 - aFrac), h);
    } else {
      // split horizontally (two rows)
      place(groupA, x, y,           w, h * aFrac);
      place(groupB, x, y + h*aFrac, w, h * (1 - aFrac));
    }
  }

  place(sorted, 0, 0, 1, 1);
  return results;
}

// Parse hex to RGB
function hexToRgb(hex) {
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b = parseInt(hex.slice(5,7),16);
  return [r,g,b];
}

// Shade a base color for each fitting: spread from 70% to 120% brightness
function shiftColor(hex, idx, total) {
  const [r,g,b] = hexToRgb(hex);
  const t = total <= 1 ? 0.5 : idx / (total - 1);
  // Mute by blending toward a neutral grey (160,160,160) then apply subtle brightness spread
  const grey = 160;
  const mute = 0.55; // 0 = fully grey, 1 = original color
  const mr = r * mute + grey * (1 - mute);
  const mg = g * mute + grey * (1 - mute);
  const mb = b * mute + grey * (1 - mute);
  // Subtle brightness spread across fittings: 0.88 to 1.08
  const factor = 0.88 + t * 0.20;
  const clamp = v => Math.min(255, Math.max(0, Math.round(v * factor)));
  return '#' + [clamp(mr), clamp(mg), clamp(mb)].map(x => x.toString(16).padStart(2,'0')).join('');
}

// Choose readable text color (dark or light) for a background hex
function textColor(hex) {
  const [r,g,b] = hexToRgb(hex);
  return (0.299*r + 0.587*g + 0.114*b) / 255 > 0.55
    ? 'rgba(0,0,0,0.72)' : 'rgba(255,255,255,0.92)';
}

function renderTreemap(tot, unknownPct, floOverride) {
  const GAP    = 0.003;  // gap between cells (normalised 0-1)
  const HDR    = 0.28;   // header strip height as fraction of material cell height

  // Top-level material items for outer layout
  const topItems = [
    ...state.map(m => ({ ...m, value: m.pct })),
    { id: 'unknown', name: 'Unknown', color: '#c0b8aa', value: unknownPct, pct: unknownPct, fittings: [] }
  ].filter(d => d.value > 0);

  const matCells = treemapLayout(topItems);
  const px = v => (v * 100).toFixed(3) + '%';
  let html = '';

  matCells.forEach(mc => {
    const hasFittings = mc.fittings && mc.fittings.length > 0;
    const cellPxW = mc.w * 860;
    const cellPxH = mc.h * 380;

    if (!hasFittings) {
      // Unknown — flat cell
      html += `<div class="tm-cell" style="
        left:${px(mc.x+GAP)};top:${px(mc.y+GAP)};
        width:${px(mc.w-GAP*2)};height:${px(mc.h-GAP*2)};
        background:${mc.color}" title="Unknown: ${mc.pct.toFixed(1)}%">
        ${cellPxW > 55 && cellPxH > 28 ? `<span class="tm-name" style="color:rgba(0,0,0,0.4)">Unknown</span><span class="tm-pct" style="color:rgba(0,0,0,0.3)">${mc.pct.toFixed(1)}%</span>` : ''}
      </div>`;
      return;
    }

    // Header strip (material label)
    const showHdr = cellPxH > 38 && cellPxW > 40;
    const hdrH = showHdr ? HDR * mc.h : 0.04 * mc.h;

    const mHomes = fmt(toHomes(mc.pct));
    const _mFloBase = floOverride !== undefined ? floOverride : TABS[currentTab].flo;
    const mFlo   = fmtFlo(Math.round(mc.pct / 100 * _mFloBase));
    const tc0    = textColor(mc.color);
    html += `<div class="tm-cell tm-hdr" style="
      left:${px(mc.x+GAP)};top:${px(mc.y+GAP)};
      width:${px(mc.w-GAP*2)};height:${px(hdrH)};
      background:${mc.color};flex-direction:column;gap:0" title="${mc.name}: ${mFlo} Flo units · ${mc.pct.toFixed(1)}% · ${mHomes} homes (78M base)">
      ${showHdr ? (() => {
        const hdrPxW = mc.w * 860;
        const hdrPxH = hdrH * 380;
        const mLines = (hdrPxH > 56 ? 4 : hdrPxH > 42 ? 3 : hdrPxH > 28 ? 2 : 1);
        const mFsPx  = Math.min(12, Math.max(7, Math.min(hdrPxW / 8, hdrPxH / (mLines * 1.25 * 1.6))));
        const mFs    = mFsPx.toFixed(1) + 'px';
        const mFsLg  = (mFsPx * 1.2).toFixed(1) + 'px';
        return `
          <span class="tm-mat-name"  style="color:${tc0};font-size:${mFsLg}">${mc.name}</span>
          ${hdrPxH > 28 ? `<span class="tm-val-flo"   style="color:${tc0};font-size:${mFs}">${mFlo} units</span>` : ''}
          ${hdrPxH > 42 ? `<span class="tm-val-pct"   style="color:${tc0};font-size:${mFs};opacity:0.8">${mc.pct.toFixed(1)}%</span>` : ''}
          
        `;
      })() : ''}
    </div>`;

    // Fitting area
    const faX = mc.x + GAP;
    const faY = mc.y + hdrH + GAP;
    const faW = mc.w - GAP * 2;
    const faH = mc.h - hdrH - GAP * 3;
    if (faW <= 0 || faH <= 0) return;

    const fitItems = mc.fittings.map((f, fi) => ({
      ...f, value: f.share, fi, total: mc.fittings.length
    }));

    const fitCells = treemapLayout(fitItems);

    fitCells.forEach(fc => {
      const bg = shiftColor(mc.color, fc.fi, fc.total);
      const tc = textColor(bg);
      const ax = faX + fc.x * faW;
      const ay = faY + fc.y * faH;
      const aw = fc.w * faW;
      const ah = fc.h * faH;
      const fpxW = aw * 860;
      const fpxH = ah * 380;
      const fpRaw = mc.pct * fc.value;          // exact % of total, unrounded
      const fp = fpRaw.toFixed(1);              // display string only
      const _floBase = floOverride !== undefined ? floOverride : TABS[currentTab].flo;
      const fpFloCount = Math.round(fpRaw / 100 * _floBase);

      // Shorten name for display
      let short = fc.name
        .replace(' male adapter', '')
        .replace(' (SharkBite)', ' (SB)')
        .replace('Dielectric union to threaded nipple', 'Dielectric union')
        .replace('Fernco rubber coupling to threaded nipple', 'Fernco coupling')
        .replace('Crimp/clamp insert ', 'Crimp ')
        .replace('Expansion insert ', 'Expan. ')
        .replace('Threaded NPT (rethread direct)', 'Threaded NPT')
        .replace('Solvent cement', 'Solvent')
        .trim();

      const fHomes = fmt(toHomes(parseFloat(fp)));
      const fFlo   = fmtFlo(fpFloCount);
      // Base font size fitted to cell: cap at 11px, scale down for narrow/short cells
      // Scale font to physically fit inside cell in both dimensions
      const nLines  = (fpxH > 52 ? 4 : fpxH > 38 ? 3 : fpxH > 22 ? 2 : 1);
      const fsPx    = Math.min(11, Math.max(6, Math.min(fpxW / 6.5, fpxH / (nLines * 1.4 * 1.5))));
      const fs      = fsPx.toFixed(1) + 'px';
      const fsLg    = (fsPx * 1.15).toFixed(1) + 'px';
      html += `<div class="tm-cell tm-fit" style="
        left:${px(ax+GAP/2)};top:${px(ay+GAP/2)};
        width:${px(aw-GAP)};height:${px(ah-GAP)};
        background:${bg};flex-direction:column;gap:1px;padding:2px 2px" title="${fc.name}: ${fFlo} Flo units · ${fp}%">
        ${fpxW > 20 && fpxH > 10 ? `<span class="tm-val-name"  style="color:${tc};font-size:${fsLg}">${short}</span>` : ''}
        ${fpxW > 20 && fpxH > 20 ? `<span class="tm-val-flo"   style="color:${tc};font-size:${fs}">${fFlo} units</span>` : ''}
        ${fpxW > 20 && fpxH > 32 ? `<span class="tm-val-pct"   style="color:${tc};font-size:${fs};opacity:0.8">${fp}%</span>` : ''}
        
      </div>`;
    });
  });

  return `
    <div class="treemap-wrap">
      <div class="bar-label">Proportional share of ${fmtFlo(TABS[currentTab].flo)} Flo units · area = % of total · fittings nested within materials</div>
      <div id="treemap-canvas">${html}</div>
    </div>`;
}

function exportTreemap() {
  // For split tab, capture the treemap-wrap + totals + key inside the tab-panel.
  // For normal tabs, capture the .left-col as before.
  const isSplit = TABS[currentTab].isSplit;

  let target;
  if (isSplit) {
    // Wrap treemap-wrap, totals-row, and split-key into a temporary capture div
    const panel = document.querySelector('.tab-panel');
    const landscape = panel.querySelector('.split-landscape');
    if (!landscape) { alert('Nothing to export.'); return; }
    const wrapper = document.createElement('div');
    wrapper.style.cssText = 'background:#f5f0e8;padding:12px;display:block;font-family:DM Mono,monospace;width:1060px';
    wrapper.appendChild(landscape.cloneNode(true));
    document.body.appendChild(wrapper);
    target = wrapper;
  } else {
    target = document.querySelector('.left-col');
    if (!target) { alert('Nothing to export.'); return; }
  }

  const tabLabel = TABS[currentTab].label;
  const btn = document.querySelector('.export-btn');
  const orig = btn.textContent;
  btn.textContent = '⏳ Exporting…';
  btn.disabled = true;

  const prevBg = isSplit ? null : target.style.background;
  if (!isSplit) target.style.background = '#f5f0e8';

  html2canvas(target, {
    backgroundColor: '#f5f0e8',
    scale: 2,
    useCORS: true,
    logging: false,
  }).then(canvas => {
    if (isSplit) { document.body.removeChild(target); }
    else { target.style.background = prevBg; }
    const link = document.createElement('a');
    link.download = `pipe-materials-${tabLabel.replace(/[^a-z0-9]/gi, '-').toLowerCase()}.png`;
    link.href = canvas.toDataURL('image/png');
    link.click();
    btn.textContent = '✓ Exported';
    btn.disabled = false;
    setTimeout(() => { btn.textContent = orig; }, 1800);
  }).catch(err => {
    if (isSplit && document.body.contains(target)) { document.body.removeChild(target); }
    else if (!isSplit) { target.style.background = prevBg; }
    console.error(err);
    btn.textContent = 'Error';
    btn.disabled = false;
    setTimeout(() => { btn.textContent = orig; }, 1800);
  });
}

function renderSplitTab() {
  const tabDef   = TABS[currentTab];
  const models   = tabDef.splitModels || SPLIT_MODELS;
  const OVERALL  = tabDef.flo;
  const GAP  = 0.003;
  const GGAP = 0.006;  // larger gap between model regions
  const MODEL_HDR = 0.07;  // model label strip as fraction of model region height
  const MAT_HDR   = 0.22;  // material label strip as fraction of material region height

  const px = v => (v * 100).toFixed(3) + '%';
  const modelColors = { '900-001': '#b5541a', '900-006': '#2a5a8a', '900-002': '#5a6e4a' };
  let html = '';

  // ── Level 1: split canvas by model proportions ──────────────────────────
  const modelItems = models.map(m => ({ ...m, value: m.flo / OVERALL }));
  const modelRegions = treemapLayout(modelItems);

  modelRegions.forEach((mr, mi) => {
    const model   = mr;
    const mColor  = modelColors[model.label] || '#888';
    const mPct    = (model.flo / OVERALL * 100).toFixed(1);
    const mPxW    = mr.w * 860;
    const mPxH    = mr.h * 520;

    // Model border overlay
    html += `<div style="
      position:absolute;left:${px(mr.x)};top:${px(mr.y)};
      width:${px(mr.w)};height:${px(mr.h)};
      border:2px solid ${mColor};border-radius:3px;
      box-sizing:border-box;pointer-events:none;z-index:4"></div>`;

    // Model header strip
    const showMHdr = mPxH > 24 && mPxW > 40;
    const mHdrH = showMHdr ? MODEL_HDR * mr.h : 0.04 * mr.h;
    const mFsPx = Math.min(11, Math.max(7, Math.min(mPxW / 9, mHdrH * 520 / 1.6)));
    html += `<div class="tm-cell" style="
      left:${px(mr.x+GGAP)};top:${px(mr.y+GGAP)};
      width:${px(mr.w-GGAP*2)};height:${px(mHdrH-GGAP)};
      background:${mColor};flex-direction:row;gap:5px;
      padding:0 6px;z-index:3;border-radius:2px 2px 0 0">
      ${showMHdr ? `
        <span style="font-size:${(mFsPx*1.1).toFixed(1)}px;font-weight:700;color:#fff;
          text-decoration:underline;text-underline-offset:2px;
          font-family:'DM Mono',monospace;letter-spacing:0.04em">${model.label}</span>
        <span style="font-size:${mFsPx.toFixed(1)}px;color:rgba(255,255,255,0.75);
          font-family:'DM Mono',monospace">${fmtFlo(model.flo)} · ${mPct}%</span>
      ` : ''}
    </div>`;

    // Area available for materials (below model header)
    const matAreaX = mr.x + GGAP;
    const matAreaY = mr.y + mHdrH;
    const matAreaW = mr.w - GGAP * 2;
    const matAreaH = mr.h - mHdrH - GGAP * 2;
    if (matAreaW <= 0 || matAreaH <= 0) return;

    // ── Level 2: split model region by material proportions ─────────────
    // Unknown gets its own material-level slice
    const unknownPct = Math.max(0, 100 - totalPct());
    const matItems = [
      ...state.map(mat => ({ ...mat, value: mat.pct / 100, isUnknown: false })),
      ...(unknownPct > 0 ? [{ id: 'unknown', name: 'Unknown', color: '#c0b8aa',
          value: unknownPct / 100, isUnknown: true, fittings: [{ name: 'Unknown', share: 1 }] }] : [])
    ].filter(m => m.value > 0);

    const matCells = treemapLayout(matItems);

    matCells.forEach(mc => {
      const mat    = mc;
      const matX   = matAreaX + mc.x * matAreaW;
      const matY   = matAreaY + mc.y * matAreaH;
      const matW   = mc.w * matAreaW;
      const matH   = mc.h * matAreaH;
      const matPxW = matW * 860;
      const matPxH = matH * 520;

      if (mat.isUnknown) {
        // Render unknown as a flat cell
        const uUnits = Math.round(model.flo / OVERALL * unknownPct / 100 * OVERALL);
        html += `<div class="tm-cell" style="
          left:${px(matX+GAP)};top:${px(matY+GAP)};
          width:${px(matW-GAP*2)};height:${px(matH-GAP*2)};
          background:#c0b8aa;flex-direction:column"
          title="${model.label} · Unknown · ${(model.flo / OVERALL * unknownPct / 100 * 100).toFixed(2)}% of total">
          ${matPxW > 30 && matPxH > 14 ? `<span style="font-size:9px;color:rgba(0,0,0,0.4)">Unknown</span>` : ''}
        </div>`;
        return;
      }

      // Material header strip
      const showMatHdr = matPxH > 28 && matPxW > 30;
      const matHdrH = showMatHdr ? MAT_HDR * matH : 0.06 * matH;
      const matTc   = textColor(mat.color);
      const matFsPx = Math.min(10, Math.max(6, Math.min(matPxW / 8, matHdrH * 520 / 1.6)));

      // Material header: colored strip with name label
      html += `<div class="tm-cell tm-hdr" style="
        left:${px(matX+GAP)};top:${px(matY+GAP)};
        width:${px(matW-GAP*2)};height:${px(matHdrH-GAP)};
        background:${mat.color};flex-direction:column;gap:1px;padding:2px 4px"
        title="${model.label} · ${mat.name}: ${(model.flo / OVERALL * mat.pct).toFixed(1)}%">
        ${matPxW > 30 && matPxH > 16 ? `<span class="tm-mat-name" style="color:${matTc};font-size:${matFsPx.toFixed(1)}px">${mat.name}</span>` : ''}
      </div>`;

      // Area for fittings
      const fitAreaX = matX + GAP;
      const fitAreaY = matY + matHdrH;
      const fitAreaW = matW - GAP * 2;
      const fitAreaH = matH - matHdrH - GAP * 2;
      if (fitAreaW <= 0 || fitAreaH <= 0) return;

      // ── Level 3: split material region by fitting shares ──────────────
      const fitItems = mat.fittings.map((f, fi) => ({ ...f, value: f.share, fi, total: mat.fittings.length }));
      const fitCells = treemapLayout(fitItems);

      fitCells.forEach(fc => {
        const bg   = shiftColor(mat.color, fc.fi, fc.total);
        const tc   = textColor(bg);
        const ax   = fitAreaX + fc.x * fitAreaW;
        const ay   = fitAreaY + fc.y * fitAreaH;
        const aw   = fc.w * fitAreaW;
        const ah   = fc.h * fitAreaH;
        const fpxW = aw * 860;
        const fpxH = ah * 520;

        // Units = model.flo × mat.pct/100 × fitting.share
        const units = Math.round(model.flo * mat.pct / 100 * fc.share);
        const pctOfTotal = (model.flo / OVERALL * mat.pct / 100 * fc.share * 100).toFixed(2);

        const nLines = fpxH > 52 ? 3 : fpxH > 32 ? 2 : 1;
        const fsPx   = Math.min(11, Math.max(6, Math.min(fpxW / 6.5, fpxH / (nLines * 1.4 * 1.5))));
        const fs     = fsPx.toFixed(1) + 'px';
        const fsLg   = (fsPx * 1.15).toFixed(1) + 'px';

        let short = fc.name
          .replace(' male adapter', '').replace(' (SharkBite)', ' (SB)')
          .replace('Dielectric union to threaded nipple', 'Dielectric union')
          .replace('Fernco rubber coupling to threaded nipple', 'Fernco')
          .replace('Crimp/clamp insert ', 'Crimp ').replace('Expansion insert ', 'Expan. ')
          .replace('Threaded NPT (rethread direct)', 'NPT').replace('Solvent cement', 'Solvent').trim();

        html += `<div class="tm-cell tm-fit" style="
          left:${px(ax+GAP/2)};top:${px(ay+GAP/2)};
          width:${px(aw-GAP)};height:${px(ah-GAP)};
          background:${bg};flex-direction:column;gap:1px;padding:2px 2px"
          title="${model.label} · ${mat.name} · ${fc.name}: ${pctOfTotal}% of total">
          ${fpxW > 20 && fpxH > 10 ? `<span class="tm-val-pct" style="color:${tc};font-size:${fs};font-weight:600">${pctOfTotal}%</span>` : ''}
        </div>`;
      });
    });
  });

  // Build material + fitting key
  const keyHtml = state.map(mat => {
    // Short fitting names (same logic as cell rendering)
    const fitRows = mat.fittings.map((f, fi) => {
      const bg = shiftColor(mat.color, fi, mat.fittings.length);
      let short = f.name
        .replace(' male adapter', '').replace(' (SharkBite)', ' (SB)')
        .replace('Dielectric union to threaded nipple', 'Dielectric union')
        .replace('Fernco rubber coupling to threaded nipple', 'Fernco')
        .replace('Crimp/clamp insert ', 'Crimp ').replace('Expansion insert ', 'Expan. ')
        .replace('Threaded NPT (rethread direct)', 'NPT').replace('Solvent cement', 'Solvent').trim();
      return `<div class="key-fit-item">
        <div class="key-swatch key-fit-swatch" style="background:${bg}"></div>
        <span class="key-fit-label">${short}</span>
      </div>`;
    }).join('');
    return `<div class="key-mat-group">
      <div class="key-mat-header">
        <div class="key-swatch" style="background:${mat.color}"></div>
        <span class="key-label">${mat.name}</span>
      </div>
      <div class="key-fit-list">${fitRows}</div>
    </div>`;
  }).join('');

  return `
    <div class="split-landscape">
      <div class="treemap-wrap" style="padding:8px 10px">
        <div class="bar-label">By model · area = % of ${tabDef.splitModels ? "¾\" + 1¼\" install base" : "total install base"} · hover for detail</div>
        <div id="treemap-canvas" style="height:440px">${html}</div>
      </div>
      <div class="split-key">${keyHtml}</div>
      <div class="totals-row">
        <div class="total-card dark">
          <div class="tc-label">Total accounted</div>
          <div class="tc-value">${totalPct().toFixed(1)}%</div>
          <div class="tc-homes">across all models</div>
        </div>
        <div class="total-card light">
          <div class="tc-label">Unknown / unaccounted</div>
          <div class="tc-value" style="color:var(--text-muted)">${Math.max(0,100-totalPct()).toFixed(1)}%</div>
          <div class="tc-homes">of install base</div>
        </div>
      </div>
    </div>`;
}


function render() {
