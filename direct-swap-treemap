<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Residential Water Main Pipe Materials</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Instrument+Serif:ital@0;1&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #f5f0e8;
    --surface: #ede8de;
    --surface2: #e4ddd0;
    --border: #c8bfaa;
    --text: #1a1612;
    --text-muted: #7a6e60;
    --unknown: #c0b8aa;
    --total-bg: #1a1612;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    min-height: 100vh;
    padding: 16px 20px 20px;
  }

  header { max-width: 1100px; margin: 0 auto 12px; display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap; }

  h1 {
    font-family: 'Instrument Serif', serif;
    font-size: 1.2rem;
    font-weight: 400;
    line-height: 1.15;
    margin-bottom: 0;
    white-space: nowrap;
  }
  h1 em { font-style: italic; color: var(--text-muted); }

  .subtitle {
    font-size: 0.58rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1.4;
  }

  .container { max-width: 1100px; margin: 0 auto; display: grid; gap: 10px; }

  /* Side-by-side layout */
  .main-layout {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .left-col { display: flex; flex-direction: column; gap: 8px; padding: 0; }
  .right-col {
    display: flex;
    flex-direction: column;
    gap: 6px;
    border-top: 1px solid var(--border);
    padding: 12px 14px;
    background: var(--surface);
  }

  /* Split tab layout */
  .split-layout {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
  }
  .split-col {
    display: flex;
    flex-direction: column;
    gap: 6px;
    border-right: 1px solid var(--border);
    padding: 10px 12px;
  }
  .split-col:last-child { border-right: none; }
  .split-col-header {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
  }
  .split-col-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text);
  }
  .split-col-meta {
    font-size: 0.55rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  /* Treemap */
  .treemap-wrap {
    background: var(--surface);
    padding: 10px 14px;
  }
  .split-col .treemap-wrap { padding: 6px 4px; }
  .split-col #treemap-canvas { height: 240px !important; }
  .bar-label {
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 8px;
  }
  #treemap-canvas {
    width: 100%;
    height: 380px;
    border-radius: 3px;
    overflow: hidden;
    position: relative;
  }
  .tm-cell {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    overflow: hidden;
    box-sizing: border-box;
    transition: left 0.35s cubic-bezier(.4,0,.2,1),
                top 0.35s cubic-bezier(.4,0,.2,1),
                width 0.35s cubic-bezier(.4,0,.2,1),
                height 0.35s cubic-bezier(.4,0,.2,1);
  }
  .tm-hdr {
    border-bottom: 1px solid rgba(255,255,255,0.25);
    flex-direction: row;
    justify-content: center;
    gap: 4px;
  }
  /* Shared value hierarchy inside every treemap cell */
  .tm-val-name, .tm-val-flo, .tm-val-pct, .tm-val-homes {
    pointer-events: none;
    white-space: normal;
    word-break: break-word;
    overflow-wrap: break-word;
    text-align: center;
    width: 100%;
    padding: 0 4px;
    line-height: 1.25;
    box-sizing: border-box;
    overflow: hidden;
  }
  .tm-val-name {
    font-size: 0.78rem;
    font-weight: 700;
    font-style: italic;
  }
  .tm-mat-name {
    font-size: 0.78rem;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
  }
  .tm-val-flo   { font-size: 0.68rem; font-weight: 600; opacity: 0.95; }
  .tm-val-pct   { font-size: 0.58rem; font-weight: 400; opacity: 0.80; }
  .tm-val-homes { font-size: 0.50rem; font-weight: 300; opacity: 0.60; }
  .tm-name {
    font-size: 0.65rem;
    font-weight: 500;
    color: rgba(255,255,255,0.92);
    text-align: center;
    line-height: 1.3;
    pointer-events: none;
    padding: 0 6px;
  }
  .tm-pct {
    font-size: 0.55rem;
    color: rgba(255,255,255,0.6);
    pointer-events: none;
    margin-top: 2px;
  }

  /* Totals */
  .totals-row { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
  .total-card { border-radius: 4px; padding: 8px 12px; }
  .total-card.dark { background: var(--total-bg); color: #f5f0e8; }
  .total-card.light { background: var(--surface2); border: 1px solid var(--border); }
  .tc-label { font-size: 0.52rem; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.5; margin-bottom: 2px; }
  .tc-value { font-size: 1.1rem; font-weight: 500; line-height: 1; }
  .tc-homes { font-size: 0.52rem; opacity: 0.45; margin-top: 2px; }

  /* Controls */
  .controls-row { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 4px; }
  .controls-note { font-size: 0.52rem; color: var(--text-muted); font-style: italic; }
  .reset-btn {
    background: none; border: 1px solid var(--border); border-radius: 3px;
    padding: 5px 12px; font-family: 'DM Mono', monospace; font-size: 0.6rem;
    letter-spacing: 0.05em; text-transform: uppercase; cursor: pointer;
    color: var(--text-muted); transition: all 0.15s;
  }
  .reset-btn:hover { color: var(--text); border-color: var(--text-muted); }
  .save-btn { border-color: var(--border); margin-left: 4px; }
  .save-btn:hover { color: var(--text); border-color: var(--text-muted); }
  .export-btn { border-color: var(--border); margin-left: 4px; }
  .export-btn:hover { color: var(--text); border-color: var(--text-muted); }

  /* Material panels */
  .materials { display: grid; gap: 10px; }

  .mat-panel {
    border: 1px solid var(--border);
    border-left: 4px solid;
    border-radius: 4px;
    background: var(--surface);
    overflow: hidden;
  }

  /* Header row: name | slider | pct | homes */
  .mat-top {
    display: grid;
    grid-template-columns: 110px 1fr 48px 72px;
    align-items: center;
    gap: 8px;
    padding: 7px 10px;
  }

  .mat-name {
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .slider-wrap { display: flex; align-items: center; gap: 6px; }
  .slider-wrap input[type=range] {
    -webkit-appearance: none;
    flex: 1;
    height: 3px;
    border-radius: 2px;
    background: var(--border);
    outline: none;
    cursor: pointer;
  }
  .sl-end { font-size: 0.54rem; color: var(--text-muted); min-width: 20px; }
  .sl-end.r { text-align: right; }

  .mat-pct-val { font-size: 0.9rem; font-weight: 500; text-align: right; }
  .mat-homes-val { font-size: 0.52rem; color: var(--text-muted); text-align: right; }

  /* Fittings */
  .fittings-section { border-top: 1px solid var(--border); }

  .fit-header {
    display: grid;
    grid-template-columns: 1fr 70px 72px;
    gap: 6px;
    padding: 4px 10px 4px 20px;
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
    font-size: 0.50rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .fit-header span:not(:first-child) { text-align: right; }

  .fit-row {
    padding: 4px 10px 3px 20px;
    border-bottom: 1px solid rgba(0,0,0,0.04);
  }
  .fit-slider-row {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 4px 0 2px;
  }
  .fit-slider-row input[type=range] {
    -webkit-appearance: none;
    flex: 1;
    height: 3px;
    border-radius: 2px;
    background: var(--border);
    outline: none;
    cursor: pointer;
  }
  .fit-row:last-child { border-bottom: none; }

  .fit-main {
    display: grid;
    grid-template-columns: 1fr 70px 88px;
    gap: 8px;
    align-items: baseline;
    margin-bottom: 4px;
  }

  .fit-name { font-size: 0.6rem; color: var(--text-muted); }
  .fit-name::before { content: '↳ '; opacity: 0.4; }

  .fit-pct { font-size: 0.7rem; font-weight: 500; text-align: right; font-variant-numeric: tabular-nums; }
  .fit-homes { font-size: 0.56rem; color: var(--text-muted); text-align: right; font-variant-numeric: tabular-nums; }

  .fit-bar-bg { height: 3px; background: rgba(0,0,0,0.08); border-radius: 2px; overflow: hidden; }
  .fit-bar-fill { height: 100%; border-radius: 2px; transition: width 0.3s ease; }

  footer {
    max-width: 900px;
    margin: 24px auto 0;
    font-size: 0.57rem;
    color: var(--text-muted);
    line-height: 1.8;
    border-top: 1px solid var(--border);
    padding-top: 14px;
  }

  /* ── Tabs ── */
  .tabs {
    display: flex;
    gap: 2px;
    margin-bottom: -1px;
    position: relative;
    z-index: 1;
  }
  .tab-btn {
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 5px 12px;
    border: 1px solid var(--border);
    border-bottom: none;
    border-radius: 4px 4px 0 0;
    background: var(--surface2);
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .tab-btn:hover { background: var(--surface); color: var(--text); }
  .tab-btn.active {
    background: var(--surface);
    color: var(--text);
    font-weight: 600;
    border-color: var(--border);
    position: relative;
  }
  .tab-btn.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0; right: 0;
    height: 2px;
    background: var(--surface);
  }
  .tab-panel {
    border: 1px solid var(--border);
    border-radius: 0 4px 4px 4px;
    overflow: hidden;
  }
  .tab-subtitle {
    font-size: 0.6rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 8px 18px;
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
  }

  /* By Model landscape layout */
  .split-landscape {
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
  }
  /* By Model key (legacy horizontal — kept for potential reuse) */
  .split-key {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 24px;
    padding: 10px 14px;
    background: var(--surface2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .key-mat-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .key-mat-header {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .key-swatch {
    width: 12px;
    height: 12px;
    border-radius: 2px;
    flex-shrink: 0;
  }
  .key-label {
    font-size: 0.62rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.03em;
  }
  .key-fit-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-left: 6px;
    border-left: 2px solid var(--border);
    margin-left: 5px;
  }
  .key-fit-item {
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .key-fit-swatch {
    width: 10px;
    height: 10px;
    border-radius: 1px;
    flex-shrink: 0;
  }
  .key-fit-label {
    font-size: 0.56rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
